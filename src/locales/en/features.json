      "categories": {
        "general": "General",
        "privacy": "Privacy",
        "features": "Features"
      },
      "localFirst": {
        "question": "What does 'Local-First' mean?",
        "answer": "'Local-First' means that all your data, such as recipes, pantry stock, and plans, is stored primarily on your device. There is no cloud database that we control. That guarantees maximum speed, privacy, and offline availability."
      },
      "aiPrivacy": {
        "question": "What happens to my data when using AI Chef?",
        "answer": "Only the text of your request, such as ingredients and preferences, is sent to the Google Gemini API. Your personal pantry data or meal plans do not leave your device unless they are explicitly part of the request."
      },
      "pantryColor": {
        "question": "What do the colors in the meal planner mean?",
        "answer": "The bar under a dish shows ingredient availability: green means everything is available, yellow means some items are missing, and red means many items are missing. That way you can immediately see whether you need to shop."
      },
      "syncDevices": {
        "question": "Can I sync data between devices?",
        "answer": "CulinaSync is currently designed as an offline-first app. Synchronization is planned for a later version. Until then, use the export and import function in settings."
      }
    },
