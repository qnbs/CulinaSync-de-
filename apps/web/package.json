{
  "name": "web",
  "private": true,
  "version": "0.2.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "type-check": "tsgo",
    "build": "tsgo && vite build",
    "lint": "cd ../.. && pnpm exec eslint apps/web --report-unused-disable-directives --max-warnings 0",
    "analyze:bundle": "cross-env ANALYZE=true vite build",
    "check:bundle-budget": "node ../../scripts/check-bundle-budget.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "predeploy": "pnpm run build && pnpm run check:bundle-budget",
    "verify:pages-artifact": "node ../../scripts/verify-pages-artifact.mjs dist"
  },
  "dependencies": {
    "@domain/ai-core": "workspace:*",
    "@domain/ui": "workspace:*",
    "@ericblade/quagga2": "^1.8.4",
    "@google/genai": "^1.16.0",
    "@hookform/resolvers": "^5.4.0",
    "@reduxjs/toolkit": "^2.2.6",
    "dexie": "^4.2.0",
    "dexie-react-hooks": "^4.2.0",
    "dompurify": "^3.3.1",
    "i18next": "^26.2.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^1.16.0",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.55.0",
    "react-i18next": "^17.0.8",
    "react-joyride": "^3.1.0",
    "react-redux": "^9.1.2",
    "react-window": "^2.2.7",
    "redux-persist": "^6.0.0",
    "tesseract.js": "^6.0.1",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.3.0",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/react-vite": "10.4.2",
    "@storybook/test": "8.6.18",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.5.15",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "10.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "4.1.8"
  }
}
