# =============================================================================
# CulinaSync – Umgebungsvariablen
# =============================================================================
#
# Der Gemini API-Schlüssel wird NICHT als Umgebungsvariable benötigt.
# Er wird sicher über die App-Einstellungen (UI) eingegeben und
# verschlüsselt in IndexedDB gespeichert.
#
# Platzhalter (optional, nicht sicherheitsrelevant):
APP_NAME=CulinaSync
APP_ENV=production
# NICHT verwenden: VITE_GEMINI_API_KEY=...
# API-Keys niemals in .env, localStorage oder Source-Code speichern.
#
# =============================================================================
