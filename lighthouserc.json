{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "resource-summary:script:size": ["warn", { "maxNumericValue": 160000 }],
        "resource-summary:total:size": ["warn", { "maxNumericValue": 260000 }]
      }
    }
  }
}
