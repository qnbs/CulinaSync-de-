{
  "name": "culinasync-monorepo",
  "private": true,
  "version": "0.2.4",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --filter=web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "pnpm --filter web exec playwright test",
    "check:bundle-budget": "pnpm --filter web run check:bundle-budget",
    "analyze:bundle": "pnpm --filter web run analyze:bundle",
    "images:webp": "node scripts/generate-webp-assets.mjs",
    "storybook": "pnpm --filter web run storybook",
    "build-storybook": "pnpm --filter web run build-storybook",
    "chromatic": "pnpm --filter web run chromatic",
    "check:all": "pnpm run lint && pnpm run type-check && pnpm run test && pnpm run test:scripts && pnpm run i18n:check && pnpm run build && pnpm run check:bundle-budget && pnpm audit --audit-level=high",
    "i18n:scan": "node scripts/scan-i18n-hardcoded.mjs",
    "i18n:scan:all": "node scripts/scan-i18n-hardcoded.mjs --include-tests",
    "i18n:check": "node scripts/check-i18n-locale-keys.mjs && node scripts/check-i18n-baseline.mjs",
    "i18n:check:keys": "node scripts/check-i18n-locale-keys.mjs",
    "i18n:check:baseline": "node scripts/check-i18n-baseline.mjs",
    "i18n:check:changed": "node scripts/check-i18n-hardcoded-changed.mjs",
    "i18n:baseline:update": "node scripts/update-i18n-baseline.mjs",
    "check:ts-ga": "node scripts/check-typescript-ga.mjs",
    "tauri:icons": "node scripts/generate-tauri-icons.mjs",
    "tauri:build": "node scripts/tauri-pnpm-build.mjs",
    "tauri:dev": "node scripts/tauri-pnpm-dev.mjs",
    "preview": "pnpm --filter web run preview",
    "predeploy": "pnpm --filter web run predeploy",
    "verify:deploy": "node scripts/verify-live-deployments.mjs",
    "verify:pages-artifact": "node scripts/verify-pages-artifact.mjs",
    "lighthouse:ci": "lhci autorun",
    "lighthouse:ci:mobile": "lhci autorun --config=./lighthouserc.mobile.json",
    "test:scripts": "node --test scripts/__tests__/*.test.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "0.14.0",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "react",
        "react-dom",
        "eslint",
        "vite",
        "esbuild"
      ]
    },
    "allowedDeprecatedVersions": {
      "deep-diff": "*",
      "glob": "*",
      "node-domexception": "*",
      "popper.js": "*"
    },
    "overrides": {
      "glob": "^11.0.0",
      "serialize-javascript": "^7.0.5",
      "source-map": "^0.7.4",
      "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15",
      "uuid": "^14.0.0",
      "vitest": "4.1.8",
      "@vitest/utils": "4.1.8",
      "protobufjs": "^7.5.6",
      "@babel/plugin-transform-modules-systemjs": "^7.29.4",
      "fast-uri": "^3.1.2",
      "tmp": ">=0.2.6",
      "brace-expansion": ">=5.0.6",
      "ws": ">=8.20.1",
      "cookie": ">=0.7.0"
    }
  }
}
