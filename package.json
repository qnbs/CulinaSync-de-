{
  "name": "CulinaSync",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "analyze:bundle": "ANALYZE=true vite build",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "images:webp": "node scripts/generate-webp-assets.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:scan": "node scripts/scan-i18n-hardcoded.mjs",
    "i18n:check:changed": "node scripts/check-i18n-hardcoded-changed.mjs",
    "preview": "vite preview",
    "predeploy": "npm run build && npm run check:bundle-budget && cp dist/index.html dist/404.html"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@ericblade/quagga2": "^1.8.4",
    "@faker-js/faker": "^10.3.0",
    "@google/genai": "^1.16.0",
    "@reduxjs/toolkit": "^2.2.6",
    "dexie": "^4.2.0",
    "dexie-react-hooks": "^4.2.0",
    "dompurify": "^3.3.1",
    "i18next": "^25.8.13",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.542.0",
    "papaparse": "^5.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.55.0",
    "react-i18next": "^16.5.4",
    "react-joyride": "^2.9.3",
    "react-redux": "^9.1.2",
    "react-window": "^1.8.10",
    "redux-persist": "^6.0.0",
    "tesseract.js": "^6.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "3.2.6",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/test": "8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/react-redux": "^7.1.33",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "postcss": "^8.4.47",
    "rollup-plugin-visualizer": "^5.14.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^4.0.18",
    "storybook": "8.6.18"
  }
}
