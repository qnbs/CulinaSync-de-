{
  "name": "culinasync-monorepo",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --filter=web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "pnpm --filter web exec playwright test",
    "check:bundle-budget": "pnpm --filter web run check:bundle-budget",
    "analyze:bundle": "pnpm --filter web run analyze:bundle",
    "images:webp": "node scripts/generate-webp-assets.mjs",
    "storybook": "pnpm --filter web run storybook",
    "build-storybook": "pnpm --filter web run build-storybook",
    "chromatic": "pnpm --filter web run chromatic",
    "check:all": "pnpm run lint && pnpm run type-check && pnpm run test && pnpm run build && pnpm run check:bundle-budget && pnpm audit --audit-level=high",
    "i18n:scan": "node scripts/scan-i18n-hardcoded.mjs",
    "i18n:check:changed": "node scripts/check-i18n-hardcoded-changed.mjs",
    "preview": "pnpm --filter web run preview",
    "predeploy": "pnpm --filter web run predeploy",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "sharp": "^0.34.3",
    "turbo": "^2.5.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "react",
        "react-dom",
        "eslint",
        "vite",
        "esbuild"
      ]
    },
    "allowedDeprecatedVersions": {
      "deep-diff": "*",
      "glob": "*",
      "node-domexception": "*",
      "popper.js": "*"
    },
    "overrides": {
      "glob": "^11.0.0",
      "serialize-javascript": "^7.0.5",
      "source-map": "^0.7.4",
      "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15",
      "uuid": "^14.0.0",
      "vitest": "4.0.18",
      "@vitest/utils": "4.0.18"
    }
  }
}
